{
    "name": "@acolville/gw",
    "version": "0.1.0",
    "description": "Wraps git to auto-switch the active GitHub CLI account per project before running a command.",
    "keywords": [
        "git",
        "github",
        "gh",
        "cli",
        "auth",
        "account",
        "wrapper",
        "bun"
    ],
    "homepage": "https://github.com/alexbruvv/git-wrapper#readme",
    "bugs": {
        "url": "https://github.com/alexbruvv/git-wrapper/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/alexbruvv/git-wrapper.git"
    },
    "license": "MIT",
    "author": "Alex Colville <me@acolville.co.uk>",
    "type": "module",
    "module": "src/cli.ts",
    "scripts": {
        "dev": "bun run src/cli.ts",
        "build": "bun build ./src/cli.ts --compile --outfile gw",
        "build:all": "bun run scripts/build-all.ts",
        "test": "bun test",
        "test:watch": "bun test --watch",
        "typecheck": "tsc --noEmit",
        "lint": "biome check .",
        "format": "biome check --write ."
    },
    "devDependencies": {
        "@biomejs/biome": "^2.5.1",
        "@types/bun": "^1.1.0",
        "typescript": "^5.4.0"
    }
}
